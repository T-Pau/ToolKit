import os
import sys

from typing import Any

sys.path.append(os.path.abspath(os.path.join(os.path.dirname(__file__), os.path.pardir, "python-packages")))

import enum
import yaml

import Script

class FieldType(enum.Enum):
    SINGLE = "single"
    STRING = "string"
    MULTI = "multi"
    OMIT = "omit"

class Spec:
    @staticmethod
    def decode(yaml: dict[str, Any], key: str, default_value: Any = None) -> Any:
        if yaml is not None and key in yaml:
            return yaml[key]
        else:
            return default_value

    class Settings:
        def __init__(self, yaml: dict[str, Any]) -> None:
            self.default_string_encoding = Spec.decode(yaml, "default_string_encoding")
            self.include_count = Spec.decode(yaml, "include_count", True)
            self.prefix = Spec.decode(yaml, "prefix", "")
            self.row_length = Spec.decode(yaml, "row_length")

    class Field:
        def __init__(self, yaml: dict[str, Any], settings: 'Spec.Settings') -> None:
            self.type = FieldType(Spec.decode(yaml, "type", "single"))
            self.encoding = Spec.decode(yaml, "encoding")
            self.default_value = Spec.decode(yaml, "default_value")
            self.empty_value = Spec.decode(yaml, "empty_value")
            self.length = Spec.decode(yaml, "length", 1)
            self.nul_terminate = Spec.decode(yaml, "nul_terminate", False)
            self.padding = Spec.decode(yaml, "padding", self.default_padding())

        def default_padding(self) -> int|str|None:
            if self.type == FieldType.MULTI or self.type == FieldType.SINGLE:
                return 0
            elif self.type == FieldType.STRING:
                return " "

    def decode_struct(self, yaml: dict[str, Any], parent: dict[str, Any]|None = None) -> dict[str, Any]:
        struct = {}
        for key in self.fields.keys():
            self.decode_field(yaml, key, struct, set())
        return struct
    
    def decode_field(self, yaml: dict[str, Any], key: str, struct: dict[str, Any], dependent_fields: set[str]) -> Any:
        if key in struct:
            return struct[key]
        
        if key in dependent_fields:
            raise RuntimeError(f"circular dependency in field {key}")
        dependent_fields.add(key)

        field = self.fields[key]
        if key in yaml:
            value = yaml[key]
        elif field.default_value is not None:
            value = self.parse_default_value(field.default_value, yaml, struct, dependent_fields)
        elif field.type == FieldType.MULTI:
            value = []
        elif field.type == FieldType.OMIT:
            value = None
        else:
            raise RuntimeError(f"no known value for field {key}")

        value = self.pad_field(value, field)
        struct[key] = value
        return value
    
    def pad_field(self, value: Any, field: 'Spec.Field') -> Any:
        if field.length > 1:
            while len(value) < field.length:
                if type(value) == list:
                    value.append(field.padding)
                else:
                    value += field.padding
        return value
    
    def empty_struct(self) -> dict[str, Any]:
        struct = {}
        for key in self.fields.keys():
            field = self.fields[key]
            if field.empty_value is not None:
                value = self.parse_default_value(field.empty_value, {}, struct, set())
            elif field.default_value is not None:
                value = self.parse_default_value(field.default_value, {}, struct, set())
            elif field.type == FieldType.MULTI:
                value = []
            elif field.type == FieldType.OMIT:
                value = None
            else:
                raise RuntimeError(f"no known value for field {key}")

            struct[key] = self.pad_field(value, field)

        return struct

    def parse_default_value(self, default_value: Any, yaml: dict[str, Any], struct: dict[str, Any], dependent_fields: set[str], parent: dict[str, Any]|None = None) -> Any:
        # To allow non-string values, return directly if it doesn't contain a field reference or if it is only a field reference.
        if not isinstance(default_value, str):
            return default_value
        if default_value.find("{{") == -1:
            return default_value
        if default_value.startswith("{{") and default_value.find("}}") == len(default_value) - 2:
            field = default_value[2:-2].strip()
            if field not in self.fields:
                raise RuntimeError(f"unknown field {field} in default value '{default_value}'")
            return self.decode_field(yaml, field, struct, dependent_fields)
        
        start = 0
        value = ""
        while (braces := default_value.find("{{", start)) >= 0:
            value += default_value[start:braces]
            start = braces + 2
            end = default_value.find("}}", start)
            if end == -1:
                raise RuntimeError(f"unmatched '{{' in default value '{default_value}'")
            field = default_value[start:end].strip()
            if field not in self.fields:
                raise RuntimeError(f"unknown field {field} in default value '{default_value}'")
            value += str(self.decode_field(yaml, field, struct, dependent_fields))
            start = end + 2
        value += default_value[start:]

        return value

    def __init__(self, yaml: dict[str, Any]) -> None:
        self.settings = Spec.Settings(yaml["settings"])
        self.fields = {}
        self.structs = []
        for key in yaml["fields"].keys():
            self.fields[key] = Spec.Field(yaml["fields"][key], self.settings)

        if self.settings.row_length is not None:
            for row in yaml["structs"]:
                if isinstance(row, dict):
                    if not "structs" in row:
                        raise RuntimeError("missing 'structs' key in dictionary row")
                    row_structs = []
                    for struct in row["structs"]:
                        complete_struct = dict(struct)
                        for key in row.keys():
                            if key != "structs":
                                if key not in complete_struct:
                                    complete_struct[key] = row[key]
                        row_structs.append(complete_struct)
                else:
                    row_structs = row
                for struct in row_structs:
                    self.structs.append(self.decode_struct(struct))
                for index in range(len(row_structs), self.settings.row_length): # type: ignore
                    self.structs.append(self.empty_struct())
        else:
            for struct in yaml["structs"]:
                self.structs.append(self.decode_struct(struct))

class ParallelStruct(Script.Script):
    def __init__(self) -> None:
        super().__init__("Convert array of structs into parallel arrays.", Script.Option.assembler)
        self.arg_parser.add_argument("structs")

    # Get filename of input file.
    def input_filename(self) -> str:
        return self.args.structs

    def execute_sub(self) -> None:
        with open(self.input_filename(), "r") as stream:
            try:
                structs = Spec(yaml.safe_load(stream))
            except yaml.YAMLError as exc:
                raise RuntimeError(f"can't load structs from '{self.input_filename()}: {exc}")

        if structs.settings.include_count:
            self.assembler.data_object(f"{structs.settings.prefix}count", len(structs.structs))
        for key in structs.fields.keys():
            field = structs.fields[key]

            if field.type == FieldType.OMIT:
                continue

            if field.type == FieldType.STRING:
                encoding = field.encoding
                if encoding is None:
                    encoding = structs.settings.default_string_encoding
                for i, struct in enumerate(structs.structs):
                    self.assembler.begin_object(f"{structs.settings.prefix}{key}_{i}")
                    self.assembler.string(struct[key], encoding, field.nul_terminate)
                    self.assembler.end_object()

            self.assembler.begin_object(f"{structs.settings.prefix}{key}")
            for i, struct in enumerate(structs.structs):
                if field.type == FieldType.STRING:
                    value = f"{structs.settings.prefix}{key}_{i}"
                else:
                    value = struct[key]
                encoding = field.encoding if field.type != FieldType.STRING else None
                self.assembler.data(value, encoding)
            self.assembler.end_object()

ParallelStruct().run()
