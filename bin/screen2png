import argparse
import sys
import os


sys.path.append(os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "python-packages"))

import CharacterImage
import Palette
import Screens
import Script

class Screen2PNG(Script.Script):
   def __init__(self) -> None:
      super().__init__("Create image from screen data.", Script.Option.include_directories)
      self.arg_parser.add_argument("screen")
      self.arg_parser.add_argument("charset")
      self.arg_parser.add_argument("-D", action="append", dest="defines")
      self.arg_parser.add_argument("-p", "--palette", metavar="PALETTE", dest="palette", help="palette of output image")

   def input_filename(self) -> str | None:
      return self.args.screen

   def execute_sub(self):
      if self.args.palette:
         palette = Palette.Palette(self.args.palette.split(","))
      else:
         palette = None
      charset = CharacterImage.CharacterImage(8, 8, filename=self.find_file(self.args.charset))
      screens = Screens.Screens(self.dependencies, defines=self.args.defines, include_directories=self.args.include_directories)
      if not screens.convert(self.input_filename(), None):
         raise RuntimeError()
      image = CharacterImage.CharacterImage(8, 8, width=screens.line_length, height=screens.lines * len(screens.compressed_screens), palette=palette)

      for i, compressed_screen in enumerate(screens.compressed_screens):
         for y in range(screens.lines):
            for x in range(screens.line_length):
               char = compressed_screen[y * screens.line_length + x]
               glyph = charset.get(char)
               if glyph:
                  image.set_xy(x, i * screens.lines + y, glyph)
      
      image.image.image.save(self.output_filename())

Screen2PNG().run()
